# Copy to .env and fill in your values:
#   cp .env.example .env

# Absolute path to this repo (required for pricing bind mount in Pier job YAML)
DEEP_SWE_ROOT=/path/to/deep-swe

# Baseten API key (used as OPENAI_API_KEY / ANTHROPIC_AUTH_TOKEN / MSWEA_API_KEY in agent sandboxes)
BASETEN_API_KEY=

# Chat Completions base URL (no trailing slash)
# Model APIs: https://inference.baseten.co/v1
# Self-deployed: https://model-<model_id>.api.baseten.co/v1
BASETEN_BASE_URL=https://api.subconscious.dev/v1

# Baseten model slug, e.g. your-org/your-model
# Also update model_name in each agent yaml to match BASETEN_MODEL
BASETEN_MODEL=subconscious/tim-qwen3.6-27b
